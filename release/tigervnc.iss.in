[Setup]
#ifdef WIN64
ArchitecturesInstallIn64BitMode=x64
#endif
AppName=QuantaVNC
AppVerName=QuantaVNC @VERSION@ (@BUILD@)
AppVersion=@VERSION@
AppPublisher=QuantaVNC team
AppPublisherURL=https://github.com/dyber-pqc/QuantaVNC
DefaultDirName={pf}\QuantaVNC
DefaultGroupName=QuantaVNC
LicenseFile=@CMAKE_SOURCE_DIR@\LICENCE.TXT

[Files]
Source: "@CMAKE_BINARY_DIR@\vncviewer\vncviewer.exe"; DestDir: "{app}"; Flags: ignoreversion restartreplace;
Source: "@CMAKE_SOURCE_DIR@\README.rst"; DestDir: "{app}"; Flags: ignoreversion
Source: "@CMAKE_SOURCE_DIR@\LICENCE.TXT"; DestDir: "{app}"; Flags: ignoreversion
; MinGW runtime DLLs
Source: "@MINGW_BIN_DIR@\libgcc_s_seh-1.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libstdc++-6.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libwinpthread-1.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
; GnuTLS and crypto runtime DLLs
Source: "@MINGW_BIN_DIR@\libgnutls-30.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libnettle-8.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libhogweed-6.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libgmp-10.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\liboqs-6.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\liboqs.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libintl-8.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libiconv-2.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\zlib1.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libjpeg-8.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libfltk-1.3.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libfltk_images-1.3.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libpixman-1-0.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libp11-kit-0.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libtasn1-6.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libidn2-0.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libunistring-5.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libffi-8.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libbrotlidec.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist
Source: "@MINGW_BIN_DIR@\libbrotlicommon.dll"; DestDir: "{app}"; Flags: ignoreversion skipifsourcedoesntexist

#define LINGUAS
#define Lang
#sub AddLanguage
  #define Lang = FileRead(LINGUAS)
  Source: "@CMAKE_BINARY_DIR@\po\{#Lang}.mo"; DestDir: "{app}\locale\{#Lang}\LC_MESSAGES"; DestName: "tigervnc.mo"; Flags: ignoreversion
#endsub
#for {LINGUAS = FileOpen("@CMAKE_SOURCE_DIR@\po\LINGUAS"); !FileEof(LINGUAS); ""} AddLanguage

[Icons]
Name: "{group}\QuantaVNC"; FileName: "{app}\vncviewer.exe";
Name: "{group}\Listening QuantaVNC"; FileName: "{app}\vncviewer.exe"; Parameters: "-listen";

Name: "{group}\License"; FileName: "write.exe"; Parameters: "LICENCE.TXT"; WorkingDir: "{app}"; Flags: "useapppaths"
Name: "{group}\Read Me"; FileName: "write.exe"; Parameters: "README.rst"; WorkingDir: "{app}"; Flags: "useapppaths"
Name: "{group}\Uninstall QuantaVNC"; FileName: "{uninstallexe}"; WorkingDir: "{app}";
